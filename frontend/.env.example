# URL de l'API backend (utilisée côté serveur Next.js pour le proxy)
API_BASE_URL=http://127.0.0.1:8001

# URL de l'API backend exposée au navigateur (lecture directe)
# Utilisee aussi par la CSP frontend (connect-src).
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001

# Clé d'authentification pour les routes d'écriture backend
# Doit correspondre exactement à WRITE_API_KEY dans backend/.env
WRITE_API_KEY=changez-moi-en-production
