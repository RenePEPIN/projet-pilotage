# Default local setup (works without PostgreSQL)
DATABASE_URL=sqlite:///./data/api_tache.db

# Clé d'authentification pour les routes d'écriture (obligatoire au démarrage)
WRITE_API_KEY=changez-moi-en-production

# Origines autorisées par le middleware CORS (séparées par des virgules)
# En production, remplacer par l'URL réelle du frontend
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting derrière reverse proxy:
# - false (défaut): utiliser l'IP socket directe
# - true: lire X-Forwarded-For / X-Real-IP uniquement si la socket vient d'un proxy de confiance
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=127.0.0.1,::1,localhost

# PostgreSQL example
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/apiTache
